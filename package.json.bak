{
  "name": "one-ticket-portal",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.0 <21"
  },
  "scripts": {
    "start": "node dist/OneTicketPortal/server/main.js",
    "build:ssr": "ng build && ng run OneTicketPortal:server",
    "serve:ssr": "node dist/OneTicketPortal/server/main.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.1.0",
    "@angular/compiler": "^20.1.0",
    "@angular/core": "^20.1.0",
    "@angular/forms": "^20.1.0",
    "@angular/platform-browser": "^20.1.0",
    "@angular/platform-server": "^20.1.0",
    "@angular/router": "^20.1.0",
    "@angular/ssr": "^20.1.5",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.1.5",
    "@angular/cli": "^20.1.5",
    "@angular/compiler-cli": "^20.1.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "typescript": "~5.8.2"
  }
}